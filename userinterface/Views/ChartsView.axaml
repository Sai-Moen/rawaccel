<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             xmlns:Models="using:userinterface.Models.Charts"
			 xmlns:DataTemplates="using:userinterface.DataTemplates"
             x:Class="userinterface.Views.ChartsView">

	<ListBox Items="{Binding Charts}">
		<ListBox.ItemTemplate>
			<DataTemplate DataType="Models:Chart">
				<ContentControl Content="{Binding}" ContentTemplate="{x:Static DataTemplates:DataTemplateCharts.ChartDataTemplate}"/>
			</DataTemplate>
		</ListBox.ItemTemplate>
	</ListBox>
	
</UserControl>