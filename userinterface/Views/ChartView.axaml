<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RawAccel.Views.ChartView"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia">

	<lvc:CartesianChart Series="{Binding Series}"
						Tooltip="{x:Null}"
						UpdaterThrottler="00:00:00.001"/>
	<!--
	Tooltip of Null disappears the tooltip text that pops up and tells you the series and values.
	Since these are all just implementation details this should not be user-facing, and offers only minimal debug potential.
	
	UpdaterThrottler sets the update interval, this does not seem to affect much right now, wait until we graph a curve.
	If it needs a constant binding then use TimeSpan.fromMilliseconds(t), to have it consistent among multiple charts.
	-->
</UserControl>